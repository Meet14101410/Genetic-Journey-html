body{
  background: linear-gradient(to right,#6dd5ed,#2193b0);
  font-family: Arial, sans-serif;
  text-align: center;
  color: white;
}

h1{
  margin-top: 50px;
}

button{
  padding: 10px 20px;
  margin: 10px;
  border: none;
  border-radius: 8px;
  background: #ffcc00;
  font-size: 16px;
  cursor: pointer;
}

button:hover{
  background: #ffaa00;
}

#result{
  font-size: 20px;
  margin-top: 20px;
}
